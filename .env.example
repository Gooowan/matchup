# PostgreSQL
POSTGRES_USER=matchup
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=matchup
DB_SSL_MODE=disable          # use "require" in production

# Valkey / Redis
REDIS_ADDRESS=redis:6379

# CORS (comma-separated origins)
ALLOW_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET=change-this-to-a-long-random-secret

# MinIO / S3-compatible storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=matchup

# Email provider: resend | mailgun | mock
EMAIL_PROVIDER=mock
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Observability (all optional)
SENTRY_DSN=
OTEL_ENDPOINT=http://tempo:4318
GIN_MODE=release
GRAFANA_PASSWORD=matchup_dev

# Frontend (VITE_ prefix required)
VITE_API_URL=http://localhost:8000
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_APP_VERSION=1.0.0

# CI only — Sentry source map upload
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=matchup-frontend
