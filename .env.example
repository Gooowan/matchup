# PostgreSQL
POSTGRES_USER=matchup
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=matchup
DB_SSL_MODE=require           # "disable" only for local dev without TLS; in production use "require"
# ALLOW_DB_SSL_DISABLE=true  # uncomment ONLY when a proxy (Cloud SQL Auth Proxy, RDS Proxy) terminates TLS externally

# Valkey / Redis
REDIS_ADDRESS=redis:6379
REDIS_TLS_ENABLED=false      # set "true" in production when Redis/Valkey uses TLS

# Prometheus metrics endpoint protection
METRICS_TOKEN=              # set to a long random secret; leave empty to disable /metrics

# CORS (comma-separated origins)
ALLOW_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_output_here
# Must match what clients expect (e.g. your app's bundle ID or domain)
JWT_AUDIENCE=matchup
# Used as the JWT issuer claim (your API base URL in production)
APP_URL=http://localhost:8000
# Optional: cross-subdomain cookie sharing (e.g. ".yourdomain.com")
COOKIE_DOMAIN=

# Object storage (S3-compatible API)
#
# === Option A: local MinIO inside Docker (default, recommended for dev) ===
# All uploads live in the `minio_data` volume defined in compose.yml.
# MINIO_ENDPOINT       = service hostname inside the docker network
# MINIO_PUBLIC_ENDPOINT= URL browsers use (host port mapping)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=matchup
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
#
# === Option B: AWS S3 (production / server-side) ===
# The same minio-go client is fully S3-compatible — only the endpoint/creds change.
# Remove the `minio` service from compose.yml (or stop using it) and set:
#   MINIO_ENDPOINT=s3.<aws-region>.amazonaws.com
#   MINIO_ACCESS_KEY=<IAM access key with s3:* on the bucket>
#   MINIO_SECRET_KEY=<IAM secret key>
#   MINIO_PUBLIC_ENDPOINT=https://<bucket>.s3.<region>.amazonaws.com   (or CloudFront URL)
# The buckets `avatars`, `materials`, `photos` are auto-created on first boot.

# Email provider: resend | mailgun | mock
EMAIL_PROVIDER=mock
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Observability (all optional)
SENTRY_DSN=
OTEL_ENDPOINT=http://tempo:4318
GIN_MODE=release
GRAFANA_PASSWORD=matchup_dev

# Frontend (VITE_ prefix required)
VITE_API_URL=http://localhost:8000
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_APP_VERSION=1.0.0

# CI only — Sentry source map upload
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=matchup-frontend

# RevenueCat (IAP webhooks)
# Get webhook secret from: RevenueCat dashboard → Project → Webhooks → Shared secret
REVENUECAT_WEBHOOK_SECRET=
# JSON map of RevenueCat product IDs to local subscription UUIDs
# e.g. {"matchup_premium_monthly":"<uuid>","matchup_premium_yearly":"<uuid>"}
REVENUECAT_PLAN_MAP=

# APNs push notifications (iOS)
# Get from: Apple Developer Portal → Certificates, Identifiers & Profiles → Keys
APNS_KEY_PATH=/secrets/apns-key.p8   # path to the .p8 key file on the server
APNS_KEY_ID=                          # 10-char key ID shown in the portal
APNS_TEAM_ID=                         # 10-char team ID (top-right in dev portal)
APNS_BUNDLE_ID=com.matchup.app
APNS_ENV=development                  # "production" for App Store / TestFlight builds

# NSFW moderation (avatar upload)
# MODERATION_PROVIDER=rekognition requires AWS creds below; leave "disabled" to skip
MODERATION_PROVIDER=disabled | rekognition
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Places API (club import from Google Maps link)
# Get from: Google Cloud Console → APIs & Services → Credentials
# Requires "Places API" enabled. Leave empty to disable the feature.
GOOGLE_PLACES_API_KEY=
# Max number of Google Maps imports per day across all users (default: 50)
# Each import costs at most ~$0.07 in API calls; 50/day ≈ $105/month well within $200 free credit.
GOOGLE_PLACES_DAILY_LIMIT=50

# Google OAuth (sign-in with Google)
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create a "Web application" client for the backend ID-token verifier.
# For Capacitor/native: also create an Android (SHA-1 fingerprint) and iOS (bundle ID) client.
# GOOGLE_CLIENT_ID is used by the backend to verify ID tokens.
# The frontend uses VITE_GOOGLE_CLIENT_ID for the Google Identity Services button.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
# iOS and Android client IDs (used by Capacitor Google Auth plugin)
VITE_GOOGLE_IOS_CLIENT_ID=
VITE_GOOGLE_ANDROID_CLIENT_ID=
