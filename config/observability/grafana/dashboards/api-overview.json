{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "MatchUp API — HTTP metrics, DB pool, and business events",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Requests / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(matchup_http_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(matchup_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(matchup_http_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "title": "Request Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(matchup_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(matchup_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "title": "DB Pool Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "matchup_db_pool_acquired_conns",
          "legendFormat": "acquired",
          "refId": "A"
        },
        {
          "expr": "matchup_db_pool_idle_conns",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "matchup_db_pool_total_conns",
          "legendFormat": "total",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "id": 5,
      "title": "Swipes / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(matchup_swipe_events_total[1m])) by (action) * 60",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "id": 6,
      "title": "Matches / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(matchup_match_events_total[1m]) * 60",
          "legendFormat": "matches",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "title": "HTTP Requests by Route",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(matchup_http_requests_total[5m])) by (route, method)",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 18 },
      "id": 8,
      "title": "Cron Job Success",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(matchup_cron_job_success_total[1h])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 18 },
      "id": 9,
      "title": "Cron Job Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(matchup_cron_job_failure_total[1h])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "id": 10,
      "title": "Feed Latency P95 (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket{route=\"/matchup/feed\"}[5m])) by (le)) * 1000",
          "legendFormat": "feed P95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "id": 11,
      "title": "Key Routes P95 (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket{route=\"/matchup/feed\"}[5m])) by (le)) * 1000",
          "legendFormat": "feed",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket{route=\"/user/profile\"}[5m])) by (le)) * 1000",
          "legendFormat": "profile",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket{route=\"/chats\"}[5m])) by (le)) * 1000",
          "legendFormat": "chats",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(matchup_http_request_duration_seconds_bucket{route=\"/map/nearby/count\"}[5m])) by (le)) * 1000",
          "legendFormat": "map nearby",
          "refId": "D"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["matchup", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MatchUp — API Overview",
  "uid": "matchup-api-overview",
  "version": 1
}
